    "#     device=0,\n",
    "#     patience=30,       # early stopping\n",
    "#     freeze=0,          # fine-tune everything\n",
    "#     mosaic=0,          # turn off mosaic\n",
    "#     mixup=0,           # turn off mixup\n",
    "#     hsv_h=0, hsv_s=0, hsv_v=0,   # no color augmentation\n",
    "#     degrees=0, scale=0, translate=0, shear=0, perspective=0,\n",
    "#     val=True   # <-- ensures validation is computed\n",
    "# )\n",
    "\n",
    "#!/usr/bin/env python3\n",
    "\n",
    "from ultralytics import YOLO\n",
    "\n",
    "model = YOLO(\"yolo26n-obb.pt\")\n",
    "\n",
    "results = model.train(\n",
    "    data=yaml_path,\n",
    "    # Core\n",
    "    epochs=30,\n",
    "    imgsz=1024,\n",
    "    batch=4,              # Adjust based on VRAM\n",
    "    device=0,\n",
    "    workers=2,\n",
    "    #cache='ram',\n",
    "    \n",
    "    # Optimizer\n",
    "    optimizer='AdamW',\n",
    "    # lr0=0.001,\n",
    "    # lrf=0.01,\n",
    "    # weight_decay=0.0005,\n",
    "    \n",
    "    # Learning schedule\n",
    "    # warmup_epochs=5.0,\n",
    "    # warmup_bias_lr=0.1,\n",
    "    patience=30,\n",
    "    \n",
    "    # Augmentation - geometric\n",
    "    mosaic=1.0,\n",
    "    mixup=0.15,\n",
    "    copy_paste=0.3,\n",
    "    close_mosaic=10,\n",
    "    degrees=0,             # Already rotated in preprocessing\n",
    "    translate=0,           # Already translated in preprocessing\n",
    "    scale=0,\n",
    "    shear=0,\n",
    "    perspective=0,\n",
    "    fliplr=0,              # Already flipped in preprocessing\n",
    "    flipud=0,\n",
    "    multi_scale=False,     # Avoid deterministic conflict\n",
    "    \n",
    "    # Augmentation - color\n",
    "    hsv_h=0,               # Preserve spectral info\n",
    "    hsv_s=0,\n",
    "    hsv_v=0,\n",
    "    \n",
    "    # Training options\n",
    "    freeze=0,\n",
    "    deterministic=False,\n",
    "    amp=True,\n",
    "    \n",
    "    # Validation & logging\n",
    "    val=True,\n",
    "    save=True,\n",
    "    save_period=10,\n",
    "    plots=True,\n",
    ")\n",
    "\n",
    "print(\"Training complete.\")"
   ]
