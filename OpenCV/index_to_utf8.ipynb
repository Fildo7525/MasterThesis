    "import cv2\n",
    "import numpy as np\n",
    "from matplotlib import pyplot as plt\n",
    "import os\n",
    "import glob\n",
    "import rasterio\n",
    "import tqdm"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "c345075b",
   "metadata": {},
   "outputs": [],
   "source": [
    "all_indices = [\n",
    "    'NDVI',\n",
    "    'NGRDI',\n",
    "    'RVI',\n",
    "    'EXGR'\n",
    "]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "8d02159d",
   "metadata": {},
   "outputs": [],
   "source": [
    "def norm_index_image(image, min, max):\n",
    "    norm_image = np.clip(image, min, max)\n",
    "    norm_image = ((norm_image - min) / (max - min) * 255).astype(np.uint8)\n",
    "    return norm_image"
   ]
  },
  {
